# Copy this file to .env and fill your own keys.
# Do NOT commit .env.
PEXELS_API_KEY=

# Optional: path to MOSS-TTS-Nano directory.
# If empty, MoneyCreatorFree uses third_party/MOSS-TTS-Nano after `python -m moneycreator.cli setup-moss`.
# Example: /home/user/work/MOSS-TTS-Nano-main
MOSS_DIR=

# Optional: override output/cache dirs.
# MONEYCREATOR_OUTPUT_DIR=outputs
# MONEYCREATOR_STOCK_CACHE=stock_cache
